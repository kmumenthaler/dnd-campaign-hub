{
  "name": "dnd-campaign-hub",
  "version": "0.4.0",
  "description": "A comprehensive Obsidian plugin for managing tabletop campaigns with smart templates and automation.",
  "private": true,
  "type": "module",
  "license": "MIT",
  "author": "Kevin Mumenthaler",
  "homepage": "https://github.com/kmumenthaler/dnd-campaign-hub#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/kmumenthaler/dnd-campaign-hub.git"
  },
  "bugs": {
    "url": "https://github.com/kmumenthaler/dnd-campaign-hub/issues"
  },
  "keywords": [
    "obsidian",
    "plugin",
    "dnd",
    "ttrpg",
    "campaign",
    "gm-tools"
  ],
  "scripts": {
    "dev": "node esbuild.config.mjs --watch",
    "build": "node esbuild.config.mjs",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "node -e \"fs.rmSync('dist', { recursive: true, force: true })\"",
    "package": "npm run clean && npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "esbuild": "^0.21.5",
    "obsidian": "latest",
    "typescript": "^5.4.5",
    "vitest": "^2.1.9",
    "yaml": "^2.8.1"
  },
  "dependencies": {
    "pdf-lib": "^1.17.1"
  }
}
